# Optional: Path to claude CLI binary (defaults to 'claude' in PATH)
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Optional: Anthropic API key (needed if claude CLI requires it)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Server configuration
MERRY_PORT=3141
MERRY_ROOT=/app

# Frontend
NEXT_PUBLIC_DAEMON_URL=http://localhost:3141

# Optional: Node environment (development | production)
NODE_ENV=development

# Optional: Logging level (debug | info | warn | error)
LOG_LEVEL=info

# Optional: Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3141
